---
/**
 * ------------------------------------------------------------
 * サイト全体のベースレイアウトです。
 * 今回の修正版では、以下を主に整理しています。
 * - ロゴ / 画像 / 内部リンクの BASE_URL 対応
 * - OGP の組み立て整理
 * - タイトルや説明文を props で渡しやすくする
 * ------------------------------------------------------------
 */

import { withBase } from '../lib/url';


// 各ページから受け取る値です。
const {
  title = 'Bikakushida',
  description = 'ビカクシダの育成記録サイト',
  count = 0,
  canonicalPath = '/plants/',
} = Astro.props;

// 本番サイトの URL です。
const siteUrl = 'https://bikakushida.jp';

// canonical と OGP の URL を明示的に作ります。
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = new URL(withBase('/images/ogp.jpg'), siteUrl).toString();
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Bikakushida" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- フォント -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Noto+Serif+JP:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #f5f1e8;
        --paper: #fffdfa;
        --text: #2b2b2b;
        --muted: #7f7668;
        --line: #e0d9cc;
        --green: #3f6b3f;
        --green-soft: #dfeadf;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Noto Serif JP', serif;
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      img {
        max-width: 100%;
      }

      header {
        padding: 20px 30px;
        border-bottom: 1px solid var(--line);
        background: var(--bg);
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .left {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .logo-link {
        display: inline-flex;
      }

      .logo {
        width: 120px;
        cursor: pointer;
      }

      .brand-block {
        line-height: 1.6;
      }

      .title-main {
        font-family: 'Playfair Display', serif;
        font-size: 14px;
        color: #7a6f5a;
        letter-spacing: 1px;
      }

      .title-sub {
        display: flex;
        align-items: baseline;
        gap: 6px;
        font-size: 30px;
        letter-spacing: 1px;
      }

      .platy {
        color: var(--green);
        font-family: 'Playfair Display', serif;
        font-weight: 600;
      }

      .jp-title {
        font-family: 'Noto Serif JP', serif;
        color: #2a2a2a;
      }

      .title-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 4px;
      }

      .title-jp {
        font-size: 13px;
        font-weight: 300;
        color: #8a7f6a;
      }

      .count-badge {
        font-size: 12px;
        background: var(--green-soft);
        color: #3a5f3a;
        padding: 4px 10px;
        border-radius: 999px;
      }

      main.page {
        max-width: 1200px;
        margin: auto;
        padding: 30px;
        animation: fadeIn 0.6s ease;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      footer.site-footer {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 30px 34px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      @media (max-width: 600px) {
        header {
          padding: 16px;
        }

        .left {
          gap: 12px;
        }

        .logo {
          width: 120px;
        }

        .title-sub {
          flex-direction: column;
          align-items: flex-start;
          gap: 2px;
          font-size: 24px;
        }

        .title-row {
          flex-direction: column;
          align-items: flex-start;
          gap: 4px;
        }

        main.page {
          padding: 20px 16px;
        }

        footer.site-footer {
          padding: 0 16px 28px;
        }
      }
    </style>
  </head>
    <link rel="manifest" href={withBase('/manifest.webmanifest')} />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <meta name="theme-color" content="#4a6741" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <body>
    <header>
      <div class="header-inner">
        <div class="left">
          <!-- ロゴクリックで一覧へ戻します。 -->
          <a href={withBase('/plants/')} class="logo-link" aria-label="株一覧へ戻る">
            <img src={withBase('/images/logo.png')} alt="Bikakushida ロゴ" class="logo" />
          </a>

          <!-- ブランド表示です。 -->
          <div class="brand-block">
            <div class="title-main">bikakushida.jp</div>

            <div class="title-sub">
              <span class="platy">Platycerium</span>
              <span class="jp-title">育成記録</span>
            </div>

            <div class="title-row">
              <span class="title-jp">我が家のビカクシダたち</span>
              <span class="count-badge">株数 {count}</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="page">
      <slot />
    </main>

    <footer class="site-footer">
      <small>Personal archive of platycerium cultivation.</small>
    </footer>
  </body>
</html>
