---
/**
 * ------------------------------------------------------------
 * トップページです。
 * 今回は植物一覧そのものをトップでも見せる構成にしつつ、
 * 一覧 UI 本体は components 側へ切り出しています。
 * また、導入文は共通ファイルから読み込むようにして、
 * index.astro が複数あっても文言の整合性が崩れないようにしています。
 * ------------------------------------------------------------
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import PlantArchive from '../components/PlantArchive.astro';
import { getAllPlants } from '../lib/plants';
import { ARCHIVE_INTRO_TITLE, ARCHIVE_INTRO_TEXT } from '../lib/siteText';

// 植物一覧を取得します。
const plants = getAllPlants();
---

<BaseLayout
  title="Bikakushida"
  description="ビカクシダの育成記録サイト"
  count={plants.length}
  canonicalPath="/"
>
  <PlantArchive
    plants={plants}
    introTitle={ARCHIVE_INTRO_TITLE}
    introText={ARCHIVE_INTRO_TEXT}
  />
</BaseLayout>