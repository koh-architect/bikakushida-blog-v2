---
/**
 * ------------------------------------------------------------
 * /plants/ 一覧ページです。
 * トップページと同じ一覧 UI を使いますが、導入文だけ少し変えています。
 * ------------------------------------------------------------
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import PlantArchive from '../../components/PlantArchive.astro';
import { getAllPlants } from '../../lib/plants';

// 植物一覧を取得します。
const plants = getAllPlants();
---

<BaseLayout
  title="Plants | Bikakushida"
  description="ビカクシダの株一覧ページ"
  count={plants.length}
  canonicalPath="/plants/"
>
  <PlantArchive
    plants={plants}
    introTitle="Plant archive"
    introText="株ごとの基本情報と最新の記録をまとめたアーカイブです。"
  />
</BaseLayout>
