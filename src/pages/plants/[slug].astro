---
import fs from 'fs';
import path from 'path';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allFiles = fs.readdirSync(path.resolve('./content/plants'));
const totalCount = allFiles.length;

export async function getStaticPaths() {
  const plantsDir = path.resolve('./content/plants');
  const files = fs.readdirSync(plantsDir);

  return files.map((file) => ({
    params: { slug: file.replace('.md', '') }
  }));
}

const { slug } = Astro.params;

const content = fs.readFileSync(
  path.resolve(`./content/plants/${slug}.md`),
  'utf-8'
);

// 🔥 trim追加（重要）
const title = content.match(/title:\s*(.*)/)?.[1]?.trim() || '';
const image = content.match(/cover_image:\s*(.*)/)?.[1]?.trim() || '';
const description = content.match(/description:\s*(.*)/)?.[1]?.trim() || '';
const species = content.match(/species:\s*(.*)/)?.[1]?.trim() || '';

const acquired = content.match(/acquired_date:\s*(.*)/)?.[1]?.trim() || '';
const place = content.match(/location:\s*(.*)/)?.[1]?.trim() || '';
const mount = content.match(/mount:\s*(.*)/)?.[1]?.trim() || '';
const status = content.match(/status:\s*(.*)/)?.[1]?.trim() || '';

const diaryMatches = [...content.matchAll(
  /- date:\s*(.*)\n\s*type:\s*(.*)\n(?:\s*image:\s*(.*)\n)?\s*note:\s*(.*)/g
)];

const diary = diaryMatches
  .map(m => ({
    date: m[1],
    type: m[2],
    image: (m[3] || '').trim(),
    note: m[4]
  }))
  .sort((a, b) => new Date(b.date) - new Date(a.date));

const diaryCount = diary.length;
---

<BaseLayout title={title} count={totalCount}>

<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Noto+Serif+JP:wght@400;600&display=swap');
</style>

<!-- 🔥 画像（BASE_URL対応） -->
{image && (
  <img 
    src={import.meta.env.BASE_URL + image} 
    class="hero" 
  />
)}

<div class="title-block">
  <h1 class="title">{title}</h1>
  {species && <div class="species">{species}</div>}
  <div class="divider"></div>
</div>

<p class="description">{description}</p>

<div class="info-grid">

  <div class="info-item">
    <div class="label">入手日</div>
    <div class="value">{acquired}</div>
  </div>

  <div class="info-item">
    <div class="label">置き場所</div>
    <div class="value">{place}</div>
  </div>

  <div class="info-item">
    <div class="label">板付素材</div>
    <div class="value">{mount}</div>
  </div>

  <div class="info-item">
    <div class="label">記録数</div>
    <div class="value">{diaryCount}件</div>
  </div>

  <div class="info-item">
    <div class="label">ステータス</div>
    <div class="value status">{status}</div>
  </div>

  <div class="info-item empty"></div>

</div>

<div class="timeline">

  {diary.map((d) => (
    <div class="timeline-item">

      <div class="timeline-dot"></div>

      <div class="timeline-content">

        <div class="meta">
          {d.date} / {d.type}
        </div>

        <!-- 🔥 日誌画像も修正 -->
        {d.image && (
          <img 
            src={import.meta.env.BASE_URL + d.image}
            class="thumb" 
            onclick="openModal(this.src)" 
          />
        )}

        <p class="note">{d.note}</p>

      </div>

    </div>
  ))}

</div>

<div id="modal" class="modal" onclick="closeModal()">
  <img id="modal-img" />
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Noto+Serif+JP:wght@400;600&display=swap');

/* =========================
  基本
========================= */
.hero {
  width: 100%;
  max-height: 420px;
  object-fit: cover;
  border-radius: 14px;
  margin-bottom: 25px;
}

.title {
  font-family: 'Playfair Display', serif;
  font-size: 36px;
  color: #1f2a1f;
  margin: 0;
}

.title-block {
  margin-bottom: 20px;
}

.species {
  font-family: 'Playfair Display', serif;
  font-size: 30px;
  color: #444;
}

.description {
  font-family: 'Noto Serif JP', serif;
  line-height: 1.8;
  color: #444;
  margin-bottom: 30px;
}

/* =========================
  情報グリッド
========================= */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid #cfc4b2;
  margin-bottom: 40px;
}

.info-item {
  padding: 10px 14px;
  border-right: 1px solid #cfc4b2;
  border-bottom: 1px solid #cfc4b2;
}

.info-item:nth-child(2n) {
  border-right: none;
}

.info-item:nth-last-child(-n+2) {
  border-bottom: none;
}

.label {
  font-size: 11px;
  margin-bottom: 2px;
}

.value {
  font-size: 13px;
}

.status {
  color: #3f6b3f;
  font-weight: 600;
}

/* =========================
  タイムライン（PC）
========================= */
.timeline {
  position: relative;
  margin-top: 40px;
  padding-left: 40px; /* ←PCは余白残す */
}

.timeline::before {
  content: '';
  position: absolute;
  left: 16px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: #cfc4b2;
}

.timeline-item {
  position: relative;
  margin-bottom: 30px;
}

.timeline-dot {
  position: absolute;
  left: 6px;   /* ←ここ調整 */
  top: 6px;
  width: 10px;
  height: 10px;
  background: #6c8f5f;
  border-radius: 50%;
}

/* ❌ 中央寄せやめる（これが犯人） */
.timeline-content {
  max-width: 700px;
}

/* =========================
  日誌画像
========================= */
.thumb {
  width: 100%;
  max-width: 600px;   /* ←PCで大きく */
  border-radius: 10px;
  margin: 12px 0;     /* ←中央やめる */
  display: block;
}

.thumb:hover {
  transform: scale(1.03);
}

/* =========================
  テキスト
========================= */
.meta {
  font-size: 12px;
  color: #8a7f6a;
  margin-bottom: 6px;
  margin-left: 12px;   /* ←これ追加（重要） */
}

.note {
  font-family: 'Noto Serif JP', serif;
  font-size: 13px;
  line-height: 1.7;
}

/* =========================
  モーダル
========================= */
.modal {
  display: none;
  position: fixed;
  z-index: 999;
  inset: 0;
  background: rgba(0,0,0,0.7);
  justify-content: center;
  align-items: center;
}

.modal img {
  max-width: 90%;
  max-height: 90%;
  border-radius: 10px;
}

/* =========================
  区切り線
========================= */
.divider {
  width: 100%;
  height: 1px;
  background: linear-gradient(to right, transparent, #cfc4b2, transparent);
  margin: 18px 0 26px;
}

/* =========================
  🔥 スマホ最適化（ここが重要）
========================= */
@media (max-width: 600px) {

  .timeline {
    padding-left: 20px;   /* ←少し余白戻す */
  }

  .timeline::before {
    left: 8px;            /* ←線位置調整 */
  }

  .timeline-dot {
    left: 3px;            /* ←ドット位置調整 */
  }

  .timeline-content {
    margin-left: 10px;    /* ←これが重要 */
  }
　/* 🔥 PCだけ調整 */
@media (min-width: 601px) {

  .timeline-content {
    margin-left: 20px;   /* ←これで被り解消 */
  }

  .meta {
    margin-left: 4px;    /* ←微調整 */
  }

}
}


</style>

<script is:inline>
  function openModal(src) {
    const modal = document.getElementById('modal');
    const img = document.getElementById('modal-img');
    img.src = src;
    modal.style.display = 'flex';
  }

  function closeModal() {
    document.getElementById('modal').style.display = 'none';
  }
</script>

</BaseLayout>