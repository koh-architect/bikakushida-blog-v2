---
/**
 * ------------------------------------------------------------
 * /plants/ 一覧ページです。
 * トップページと同じ一覧 UI を使いますが、導入文だけ少し変えています。
 * ------------------------------------------------------------
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import PlantArchive from '../../components/PlantArchive.astro';
import { getAllPlants } from '../../lib/plants';

// 植物一覧を取得します。
const plants = getAllPlants();
---

<BaseLayout
  title="Plants | Bikakushida"
  description="ビカクシダの株一覧ページ"
  count={plants.length}
  canonicalPath="/plants/"
>
  <PlantArchive
    plants={plants}
    introTitle="Plant archive"
    introText="このページは、ビカクシダ初心者による育成記録のアーカイブです。株ごとの情報や日々の変化を整理しながら、少しずつ育っていく姿を記録しています。育成環境は室内、育成ライトはBrim Luna4000Kを使用しています。"
  />
</BaseLayout>
