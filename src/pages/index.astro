---
/**
 * ------------------------------------------------------------
 * トップページです。
 * 今回は植物一覧そのものをトップでも見せる構成にしつつ、
 * 一覧 UI 本体は components 側へ切り出しています。
 * ------------------------------------------------------------
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import PlantArchive from '../components/PlantArchive.astro';
import { getAllPlants } from '../lib/plants';

// 植物一覧を取得します。
const plants = getAllPlants();
---

<BaseLayout
  title="Bikakushida"
  description="ビカクシダの育成記録サイト"
  count={plants.length}
  canonicalPath="/"
>
  <PlantArchive
    plants={plants}
    introTitle="Archive"
    introText="このページは、ビカクシダ初心者による育成記録のアーカイブです。株ごとの情報や日々の変化を整理しながら、少しずつ育っていく姿を記録しています。育成環境は室内、育成ライトはBrim Luna4000Kを使用しています。"
  />
</BaseLayout>
