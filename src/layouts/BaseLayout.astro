---
const { title = "Bikakushida", count = 0 } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta property="og:title" content={title} />
<meta property="og:description" content="ビカクシダの育成記録サイト" />
<meta property="og:image" content="https://bikakushida.jp/images/ogp.jpg" />
<meta property="og:url" content="https://bikakushida.jp" />
<meta property="og:type" content="website" />

<meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- フォント -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Noto+Serif+JP:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
      /* =========================
        ベース
      ========================= */
      body {
        margin: 0;
        background: #f5f1e8;
        color: #2b2b2b;
        font-family: 'Noto Serif JP', serif;
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      /* =========================
        ヘッダー
      ========================= */
      header {
        padding: 20px 30px;
        border-bottom: 1px solid #e0d9cc;
        background: #f5f1e8;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .left {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .logo {
        width: 90px;
        cursor: pointer;
      }

      .title-block {
        line-height: 1.6;
      }

      /* 上段 */
      .title-main {
        font-family: 'Playfair Display', serif;
        font-size: 14px;
        color: #7a6f5a;
        letter-spacing: 1px;
      }

      /* メインタイトル */
      .title-sub {
  display: flex !important;
  align-items: baseline;
  gap: 6px;
  font-size: 30px;
  letter-spacing: 1px;
}

      /* Platycerium */
      .platy {
        color: #3f6b3f;
        font-family: 'Playfair Display', serif;
        font-weight: 600;
      }

      /* 育成記録 */
      .jp-title {
        font-family: 'Noto Serif JP', serif;
        color: #2a2a2a;
      }

      /* 下段 */
      .title-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 4px;
      }

      .title-jp {
        font-size: 13px;
        font-weight: 300;
        color: #8a7f6a;
      }

      .count-badge {
        font-size: 12px;
        background: #dfeadf;
        color: #3a5f3a;
        padding: 4px 10px;
        border-radius: 999px;
      }

      /* =========================
        メインエリア
      ========================= */
      .page {
        max-width: 1200px;   /* ←広げた（重要） */
        margin: auto;
        padding: 30px;
        animation: fadeIn 0.6s ease;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* =========================
        🔥 スマホ対応
      ========================= */
      @media (max-width: 600px) {

        header {
          padding: 16px 16px;
        }

        .left {
          gap: 12px;
        }

        .logo {
          width: 70px;
        }

        /* タイトル縦化（今回の本命） */
        .title-sub {
          flex-direction: column;
          align-items: flex-start;
          gap: 2px;
          font-size: 24px;
        }

        .title-row {
          flex-direction: column;
          align-items: flex-start;
          gap: 4px;
        }

        .page {
          padding: 20px 16px;
        }
      }

    </style>
  </head>

  <body>

    <header>
      <div class="header-inner">

        <div class="left">

          <!-- ロゴ -->
          <a href="/plants/">
            <img src="/images/logo.png" class="logo" />
          </a>

          <!-- タイトル -->
          <div class="title-block">

            <div class="title-main">Cultivation Journal</div>

            <div class="title-sub">
              <div class="platy">Platycerium</div>
              <div class="jp-title">育成記録</div>
            </div>

            <div class="title-row">
              <div class="title-jp">我が家のビカクシダたち</div>
              <div class="count-badge">株数：{count}</div>
            </div>

          </div>

        </div>

      </div>
    </header>

    <main class="page">
      <slot />
    </main>

  </body>
</html>