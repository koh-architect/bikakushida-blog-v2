---
/**
 * ------------------------------------------------------------
 * /plants/ 一覧ページです。
 * トップページと同じ一覧UIを使います。
 * 導入文は content/site/archive-intro.md から共通で読み込みます。
 * ------------------------------------------------------------
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import PlantArchive from '../../components/PlantArchive.astro';
import { getAllPlants } from '../../lib/plants';
import { getArchiveIntro } from '../../lib/siteContent';

// 植物一覧を取得します。
const plants = getAllPlants();

// 共通の導入文を取得します。
const archiveIntro = getArchiveIntro();
---

<BaseLayout
  title="Plants | Bikakushida"
  description="ビカクシダの株一覧ページ"
  count={plants.length}
  canonicalPath="/plants/"
>
  <PlantArchive
    plants={plants}
    introTitle={archiveIntro.archiveIntroTitle}
    introText={archiveIntro.archiveIntroText}
  />
</BaseLayout>