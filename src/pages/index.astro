---
/**
 * ------------------------------------------------------------
 * トップページです。
 * 今回は植物一覧そのものをトップでも見せる構成にしつつ、
 * 一覧 UI 本体は components 側へ切り出しています。
 * ------------------------------------------------------------
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import PlantArchive from '../components/PlantArchive.astro';
import { getAllPlants } from '../lib/plants';

// 植物一覧を取得します。
const plants = getAllPlants();
---

<BaseLayout
  title="Bikakushida"
  description="ビカクシダの育成記録サイト"
  count={plants.length}
  canonicalPath="/"
>
  <PlantArchive
    plants={plants}
    introTitle="Archive"
    introText="我が家で育てているビカクシダの記録を、更新順にまとめています。"
  />
</BaseLayout>
